package com.virtusa.telecom.notification.notification_service.service;

import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;

import com.virtusa.telecom.notification.notification_service.dto.NotificationChannel;
import com.virtusa.telecom.notification.notification_service.dto.NotificationRequest;
import com.virtusa.telecom.notification.notification_service.dto.PaymentFailedEvent;
import com.virtusa.telecom.notification.notification_service.dto.PaymentSuccessEvent;

import lombok.RequiredArgsConstructor;

@Component
@RequiredArgsConstructor
public class PaymentEventListener {

    private final NotificationManager notificationManager;

    @KafkaListener(topics = "payment-success")
    public void handlePaymentSuccess(PaymentSuccessEvent event) {

        NotificationRequest request = new NotificationRequest();
        request.setRecipient(event.getEmail());
        request.setSubject("Subscription Activated");
        request.setMessage("Your payment was successful."+event.getMessage());
        request.setRecipient(event.getPaymentId().toString());
        request.setChannel(NotificationChannel.EMAIL);

        notificationManager.sendNotification(request);
    }

    @KafkaListener(topics = "payment-failed")
    public void handlePaymentFailed(PaymentFailedEvent event) {

        NotificationRequest request = new NotificationRequest();
        request.setRecipient(event.getEmail());
        request.setSubject("Payment Failed");
        request.setMessage("Your payment failed. Please try again."+event.getFailureReason());
        request.setChannel(NotificationChannel.EMAIL);

        notificationManager.sendNotification(request);
    }
}
