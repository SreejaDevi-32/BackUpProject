server:
  port: 8085

spring:
  application:
    name: notification-service

  # ===============================
  # JPA + DATABASE CONFIGURATION
  # ===============================
  datasource:
    url:  ${SPRING_DATASOURCE_URL}
    username: ${SPRING_DATASOURCE_USERNAME}
    password: ${SPRING_DATASOURCE_PASSWORD}

  jpa:
    hibernate:
      ddl-auto: update   # use validate in production
    show-sql: true
    properties:
      hibernate:
        format_sql: true

  # ===============================
  # SMTP CONFIGURATION
  # ===============================
  mail:
    host: sandbox.smtp.mailtrap.io
    port: 2525
    username: ${SMTP_USERNAME}
    password: ${SMTP_PASSWORD}
    protocol: smtp
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
          connectiontimeout: 5000
          timeout: 5000
          writetimeout: 5000

# ===============================
# SMPP CONFIGURATION
# ===============================
#smpp:
#  host: localhost
#  port: 2775
#  system-id: testSystemId
#  password: testPassword
#  system-type: ""
#  bind-type: tx          # tx / trx
#  source-addr: SENDERID
#  source-ton: 0
#  source-npi: 0
#  dest-ton: 1
#  dest-npi: 1

smpp:
  enabled: false

# ===============================
# ASYNC CONFIGURATION
# ===============================
notification:
  async:
    core-pool-size: 5
    max-pool-size: 20
    queue-capacity: 100
    thread-name-prefix: notification-exec-

# ===============================
# RESILIENCE4J (Optional)
# ===============================
resilience4j:
  retry:
    instances:
      notificationRetry:
        max-attempts: 3
        wait-duration: 2s

  circuitbreaker:
    instances:
      notificationCircuitBreaker:
        sliding-window-size: 10
        minimum-number-of-calls: 5
        failure-rate-threshold: 50
        wait-duration-in-open-state: 10s

# ===============================
# LOGGING
# ===============================
logging:
  level:
    root: INFO
    org.springframework.mail: DEBUG
    org.jsmpp: DEBUG
  pattern:
    console: "%d{yyyy-MM-dd HH:mm:ss} - %msg%n"
