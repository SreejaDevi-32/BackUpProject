server:
  port: 8071

spring:
  application:
    name: TELECOM-CONFIG-SERVER

  cloud:
    config:
      server:
        git:
          uri: https://github.com/SreejaDevi-32/config-repo
          clone-on-start: true


logging:
  pattern:
    console: "%d{HH:mm:ss.SSS} %-5level [%thread] [%X{trace_id:-},%X{span_id:-}] %logger{36} - %msg%n"
    #level: "%5p [${spring.application.name},%X{trace_id},%X{span_id}]"

management:
  endpoints:
    web:
      exposure:
        include: "*"

  endpoint:
    health:
      probes:
        enabled: true

  health:
    readiness-state:
      enabled: true
    liveness-state:
      enabled: true

  metrics:
    tags:
      application: ${spring.application.name}